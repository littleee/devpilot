{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "include": [
    "packages/sdk-core/src/**/*.ts",
    "packages/widget/src/**/*.ts",
    "packages/react-demo/src/**/*.ts",
    "packages/react-demo/src/**/*.tsx",
    "apps/diagnostic-agent/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
